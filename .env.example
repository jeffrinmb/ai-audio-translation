# ─────────────────────────────────────────────────────────────────────────────
# AI Conference Translation Platform — Environment Variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io → your project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Frontend public URLs (browser-accessible) ─────────────────────────────────
# For local dev:
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# For Docker / production (backend behind a reverse proxy):
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ── Backend ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# PORT=4000

# ── Worker ─────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000
# PORT=4001
